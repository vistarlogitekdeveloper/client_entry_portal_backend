PORT=5000
JWT_SECRET=replace_with_strong_secret

# Supabase Postgres connection string (preferred)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Backward-compatible fallback if SUPABASE_DB_URL is not set
DATABASE_URL=

# Keep true for Supabase/Render managed Postgres
DB_SSL=true

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Portal Alerts

ENABLE_WEEKLY_REMINDER_SCHEDULER=true
